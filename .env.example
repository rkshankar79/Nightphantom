# Sanity (public — safe for browser / Vercel)
# Local editing: npm run dev → http://localhost:3000/studio (sign in, create Product docs, Publish)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Optional; defaults in sanity/env.ts if unset
# NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Server / scripts only — never expose in the browser (npm run seed:products)
# Create at https://www.sanity.io/manage → project → API → Tokens (Editor)
SANITY_API_WRITE_TOKEN=
